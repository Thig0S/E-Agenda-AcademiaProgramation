@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusao de Despesa";
}

@model ExcluirDespesaViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Excluir"
      asp-route-id="@Model.Id" method="post">
    <input asp-for="Id" type="hidden">

    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Deseja realmente excluir essa Despesa?
    </div>

    <dl class="row mb-0">
        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">ID</dt>
        <dd class="col-sm-8 text-break">@Model.Id</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Descricao</dt>
        <dd class="col-sm-8">@Model.Descricao</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Data de Ocorrencia</dt>
        <dd class="col-sm-8">@Model.DataOcorrencia.Split(" ")[0]</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Valor</dt>
        <dd class="col-sm-8">R$@Model.Valor</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Forma de Pagamento</dt>
        <dd class="col-sm-8">@Model.FormaPagamento</dd>

        @if (Model.Categoria != "Sem Categoria")
        {
            <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Categoria</dt>
            <dd class="col-sm-8">@Model.Categoria</dd>
        }
    </dl>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>
