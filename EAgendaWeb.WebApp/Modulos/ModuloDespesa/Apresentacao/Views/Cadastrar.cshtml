@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastro de Despesa";
}

@model CadastrarDespesaViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Cadastrar"
      method="post">
    <div class="mb-3">
        <label asp-for="Descricao" class="form-label fw-semibold text-primary text-uppercase small">Descricao</label>
        <input asp-for="Descricao" type="text" class="form-control">
        <span asp-validation-for="Descricao" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DataOcorrencia" class="form-label fw-semibold text-primary text-uppercase small">Data de
            Ocorrencia</label>
            <input asp-for="DataOcorrencia" type="date" class="form-control" ">
            <span asp-validation-for=" DataOcorrencia" class="text-danger small fw-semibold"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Valor" class="form-label fw-semibold text-primary text-uppercase small">Valor</label>
            <input asp-for="Valor" type="number" class="form-control">
            <span asp-validation-for="Valor" class="text-danger small fw-semibold"></span>
        </div>

        <div class="mb-3">
            <label asp-for="FormaPagamento" class="form-label fw-semibold text-primary text-uppercase small">Forma de
                Pagamento</label>
                <select asp-for="FormaPagamento" class="form-select">
                    <option value="" selected>Selecione uma opcão</option>
                    <option value="A vista">À vista</option>
                    <option value="Crédito">Crédito</option>
                    <option value="Débito">Débito</option>
                </select>
                <span asp-validation-for="FormaPagamento" class="text-danger small fw-semibold"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Categoria" class="form-label fw-semibold text-primary text-uppercase small">Categoria</label>
                <span class="text-secondary"> *Opcional*</span>

                <select asp-for="Categoria" asp-items="ViewBag.Categorias" class="form-select">
                    <option value="">Selecione um categoria...</option>
                </select>
                <span asp-validation-for="Categoria" class="text-danger small fw-semibold"></span>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
                <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
            </div>
        </form>
