@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Tarefas";
}

@model List<ListarTarefaViewModel>;

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">Cadastrar Novo</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhuma Tarefa cadastrada.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (ListarTarefaViewModel f in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0">@f.Titulo</h5>
                            <span class="badge text-bg-primary rounded-pill">@f.Id.ToString().Substring(0, 8)</span>
                        </div>

                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">Prioridade</dt>
                            <dd class="col-7 mb-0 text-break">@f.Prioridade</dd>

                            <dt class="col-5 text-secondary fw-semibold">Status de Conclusao</dt>
                            <dd class="col-7 mb-0 text-break">@f.StatusDeConclusao</dd>

                        </dl>
                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">Data de Criação</dt>
                            <dd class="col-7 mb-0 text-break">@(f.DataCricao)</dd>

                            <dt class="col-5 text-secondary fw-semibold">Data de Conclusão</dt>
                            <dd class="col-7 mb-0 text-break">@(f.DataConclusao)</dd>
                        </dl>

                        <div class="progress mb-3">
                            <div class="progress-bar bg-success" role="progressbar" style="width: @f.PercentualConcluido;"
                                 aria-valuenow="@f.PercentualConcluido" aria-valuemin="0" aria-valuemax="100">
                                @f.PercentualConcluido%
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="MostrarItens"
                               asp-route-id="@f.Id">Itens</a>
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar"
                               asp-route-id="@f.Id">Editar</a>
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir"
                               asp-route-id="@f.Id">Excluir</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
