@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Compromisso";
}

@model List<ListarCompromissoViewModel>;

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">Cadastrar Novo</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhum Compromisso cadastrado.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (ListarCompromissoViewModel f in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0">@f.Assunto</h5>
                            <span class="badge text-bg-primary rounded-pill">@f.Id.ToString().Substring(0, 8)</span>
                        </div>

                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">Tipo de Compromisso</dt>
                            <dd class="col-7 mb-0 text-break">@f.TipoDeCompromisso</dd>

                            <dt class="col-5 text-secondary fw-semibold">Data</dt>
                            <dd class="col-7 mb-0 text-break">@f.DataOcorrencia</dd>

                        </dl>

                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">Hora Início</dt>
                            <dd class="col-7 mb-0 text-break">@f.HoraInicio</dd>

                            <dt class="col-5 text-secondary fw-semibold">Hora Termino</dt>
                            <dd class="col-7 mb-0 text-break">@f.HoraTermino</dd>

                        </dl>
                        <dl class="row g-2 mb-4">
                            @if (f.TipoDeCompromisso == TipoDeCompromisso.Presencial.ToString())
                            {

                                <dt class="col-5 text-secondary fw-semibold">Local</dt>
                                <dd class="col-7 mb-0 text-break">@(f.Local ?? "Não Informado")</dd>
                            }
                            else
                            {
                                <dt class="col-5 text-secondary fw-semibold">Link</dt>
                                <dd class="col-7 mb-0 text-break">@(f.Link ?? "Não Informado")</dd>
                            }
                            <dt class="col-5 text-secondary fw-semibold">Cargo</dt>
                            <dd class="col-7 mb-0 text-break">@(f.Contato ?? "Não Informado")</dd>
                        </dl>

                        <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar"
                               asp-route-id="@f.Id">Editar</a>
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir"
                               asp-route-id="@f.Id">Excluir</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
