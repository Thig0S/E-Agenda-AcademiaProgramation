@{
    Layout = "_Layout";
    ViewBag.Titulo = "Edicao de Compromisso";

    List<SelectListItem> Contatos = ViewBag.Contatos;

}

@model EditarCompromissoViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Editar"
      asp-route-id="@Model.Id" method="post">
    <input asp-for="Id" type="hidden">

    <div class="mb-3">
        <label asp-for="Assunto" class="form-label fw-semibold text-primary text-uppercase small">Assunto</label>
        <input asp-for="Assunto" type="text" class="form-control">
        <span asp-validation-for="Assunto" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DataOcorrencia" class="form-label fw-semibold text-primary text-uppercase small">Data de
            Ocorrencia</label>
            <input asp-for="DataOcorrencia" type="date" class="form-control"
                   value="@(Model.DataOcorrencia != null ? DateTime.Parse(Model.DataOcorrencia).ToString("yyyy-MM-dd") : "")">
            <span asp-validation-for=" DataOcorrencia" class="text-danger small fw-semibold"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="HoraInicio" class="form-label fw-semibold text-primary text-uppercase small">Hora de
                Início</label>
                <input asp-for="HoraInicio" type="time" class="form-control">
                <span asp-validation-for="HoraInicio" class="text-danger small fw-semibold"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="HoraTermino" class="form-label fw-semibold text-primary text-uppercase small">Hora de
                    Término</label>
                    <input asp-for="HoraTermino" type="time" class="form-control">
                    <span asp-validation-for="HoraTermino" class="text-danger small fw-semibold"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="TipoDeCompromisso" class="form-label fw-semibold text-primary text-uppercase small">Tipo de
                    Compromisso</label>
                    <select asp-for="TipoDeCompromisso" class="form-select" id="tipoCompromisso">
                        <option value="">Selecione...</option>
                        <option value="Presencial">Presencial</option>
                        <option value="Remoto">Remoto</option>
                    </select>
                    <span asp-validation-for="TipoDeCompromisso" class="text-danger small fw-semibold"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Contato" class="form-label fw-semibold text-primary text-uppercase small">Contato</label>
                    <span class="text-secondary"> *Opcional*</span>

                    <select asp-for="Contato" asp-items="ViewBag.Contatos" class="form-select">
                        <option value="">Selecione um contato...</option>
                    </select>
                    <span asp-validation-for="Contato" class="text-danger small fw-semibold"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
                    <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
                </div>
            </form>
